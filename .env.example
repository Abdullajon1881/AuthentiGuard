# ═══════════════════════════════════════════════════════════════
# AuthentiGuard — Environment Variables
# Copy this file to .env and fill in all values.
# NEVER commit .env to version control.
# ═══════════════════════════════════════════════════════════════

# ── Application ────────────────────────────────────────────────
APP_ENV=development
APP_DEBUG=true
APP_SECRET_KEY=CHANGE_ME_generate_with_openssl_rand_hex_32

# ── Database ───────────────────────────────────────────────────
POSTGRES_USER=authentiguard
POSTGRES_PASSWORD=CHANGE_ME_strong_password
POSTGRES_DB=authentiguard
DATABASE_URL=postgresql+asyncpg://authentiguard:CHANGE_ME@localhost:5432/authentiguard

# ── Redis ──────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_strong_password
REDIS_URL=redis://:CHANGE_ME@localhost:6379/0

# ── Object Storage (MinIO / S3) ────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=CHANGE_ME_strong_password
S3_BUCKET_UPLOADS=ag-uploads
S3_BUCKET_REPORTS=ag-reports
S3_ENDPOINT_URL=http://localhost:9000
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=CHANGE_ME_strong_password
AWS_REGION=us-east-1

# ── Auth / JWT ─────────────────────────────────────────────────
JWT_SECRET_KEY=CHANGE_ME_generate_with_openssl_rand_hex_64
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30
JWT_ALGORITHM=HS256

# ── Celery ─────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://:CHANGE_ME@localhost:6379/0
CELERY_RESULT_BACKEND=redis://:CHANGE_ME@localhost:6379/1

# ── Flower (queue monitoring) ──────────────────────────────────
FLOWER_USER=admin
FLOWER_PASSWORD=CHANGE_ME_strong_password

# ── AI Model APIs (for dataset generation) ────────────────────
OPENAI_API_KEY=sk-CHANGE_ME
ANTHROPIC_API_KEY=sk-ant-CHANGE_ME

# ── Experiment Tracking ────────────────────────────────────────
MLFLOW_TRACKING_URI=http://localhost:5000
WANDB_API_KEY=CHANGE_ME

# ── Encryption ────────────────────────────────────────────────
ENCRYPTION_KEY=CHANGE_ME_generate_with_fernet_key_generate

# ── Rate Limiting ─────────────────────────────────────────────
RATE_LIMIT_FREE_TIER=10
RATE_LIMIT_PRO_TIER=100
RATE_LIMIT_ENTERPRISE_TIER=1000

# ── Frontend ──────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
