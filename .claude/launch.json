{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Next.js Frontend",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 3000
    },
    {
      "name": "FastAPI Backend",
      "runtimeExecutable": "uvicorn",
      "runtimeArgs": ["app.main:app", "--reload", "--host", "0.0.0.0", "--port", "8000"],
      "port": 8000
    },
    {
      "name": "Celery Worker",
      "runtimeExecutable": "celery",
      "runtimeArgs": ["-A", "app.workers.celery_app", "worker", "--loglevel=info", "-Q", "text,image,audio,video,code,webhook"],
      "port": null
    },
    {
      "name": "Celery Flower",
      "runtimeExecutable": "celery",
      "runtimeArgs": ["-A", "app.workers.celery_app", "flower", "--port=5555"],
      "port": 5555
    },
    {
      "name": "MLflow Tracking",
      "runtimeExecutable": "mlflow",
      "runtimeArgs": ["server", "--backend-store-uri", "postgresql://authentiguard:pass@localhost:5432/mlflow", "--default-artifact-root", "s3://mlflow-artifacts", "--host", "0.0.0.0", "--port", "5000"],
      "port": 5000
    }
  ]
}
