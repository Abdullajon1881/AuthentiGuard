# ══════════════════════════════════════════════════════════════
# AuthentiGuard Production Environment
# ══════════════════════════════════════════════════════════════
# INSTRUCTIONS:
# 1. Copy this file to .env.production on your VPS
# 2. Replace ALL values marked CHANGE_ME with strong random values
# 3. Generate secrets with: openssl rand -hex 32
# 4. Never commit this file with real values to git
# ══════════════════════════════════════════════════════════════

# ── App ──────────────────────────────────────────────────────
APP_NAME=AuthentiGuard
APP_VERSION=0.2.0
APP_ENV=production
APP_SECRET_KEY=CHANGE_ME_openssl_rand_hex_32

# ── Domain ───────────────────────────────────────────────────
DOMAIN=authentiguard.io
CORS_ORIGINS=https://authentiguard.io,https://www.authentiguard.io,https://api.authentiguard.io

# ── Database ─────────────────────────────────────────────────
POSTGRES_USER=authentiguard
POSTGRES_PASSWORD=CHANGE_ME_openssl_rand_hex_24
POSTGRES_DB=authentiguard
DATABASE_URL=postgresql+asyncpg://authentiguard:CHANGE_ME_SAME_AS_ABOVE@postgres:5432/authentiguard

# ── Redis ────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_openssl_rand_hex_24
REDIS_URL=redis://:CHANGE_ME_SAME_AS_ABOVE@redis:6379/0

# ── Celery ───────────────────────────────────────────────────
CELERY_BROKER_URL=redis://:CHANGE_ME_SAME_AS_REDIS@redis:6379/0
CELERY_RESULT_BACKEND=redis://:CHANGE_ME_SAME_AS_REDIS@redis:6379/1

# ── JWT ──────────────────────────────────────────────────────
JWT_SECRET_KEY=CHANGE_ME_openssl_rand_hex_64
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# ── MinIO (S3-compatible storage) ────────────────────────────
# Root credentials are managed via Docker secrets files:
#   ./secrets/minio_root_user, ./secrets/minio_root_password
# They are bootstrap/admin only — the app never reads them.
#
# Backend & worker use a dedicated service account (least-privilege)
# also mounted via Docker secrets:
#   ./secrets/s3_app_access_key, ./secrets/s3_app_secret_key
# See secrets/README.md for how to provision these with `mc admin`.
#
# Do NOT set AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY here in production —
# the *_FILE variants in docker-compose.prod.yml are authoritative.
S3_BUCKET_UPLOADS=authentiguard-uploads
S3_BUCKET_REPORTS=authentiguard-reports
AWS_REGION=us-east-1
S3_ENDPOINT_URL=http://minio:9000

# ── Encryption ───────────────────────────────────────────────
ENCRYPTION_KEY=CHANGE_ME_python_c_from_cryptography_fernet_generate_key

# ── Flower (Celery monitoring) ───────────────────────────────
FLOWER_USER=admin
FLOWER_PASSWORD=CHANGE_ME_openssl_rand_hex_16

# ── Rate Limiting ────────────────────────────────────────────
RATE_LIMIT_FREE_TIER=10
RATE_LIMIT_PRO_TIER=100
RATE_LIMIT_ENTERPRISE_TIER=1000

# ── File Upload Limits ───────────────────────────────────────
MAX_UPLOAD_SIZE_MB=500
UPLOAD_RETENTION_DAYS=30
REPORT_RETENTION_DAYS=365

# ── Alerting ─────────────────────────────────────────────────
# Slack-compatible incoming-webhook URL (or any generic JSON endpoint).
# Consumed by app.workers.alerting._post_alert_webhook.
# REQUIRED for production: without this, detector-fallback,
# high-failure-rate, and high-queue-depth alerts are only written to
# structlog — nothing reaches a human outside the container.
# Payload shape (Slack-compatible):
#   {"text": "[SEVERITY] AuthentiGuard: <message>",
#    "severity": "critical"|"warning",
#    "alert":    "detector_fallback"|"high_failure_rate"|"queue_depth_high:<queue>",
#    "env":      "production",
#    "timestamp": "<ISO8601>",
#    "details":  {...}}
# 15-minute per-key cooldown prevents repeat spam.
ALERT_WEBHOOK_URL=CHANGE_ME_https://hooks.slack.com/services/XXX/YYY/ZZZ
ALERT_WEBHOOK_TIMEOUT_SECONDS=5.0

# ── Sentry (crash reporting — add after signup) ──────────────
# SENTRY_DSN=https://your-key@sentry.io/your-project
